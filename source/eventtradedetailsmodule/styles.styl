#tradedetails-table
    width 100%
    border-collapse collapse
    font-size 10pt

    th, td
        padding 8px 20px
        text-align right
    td, tr
        border-left solid 1px alpha(#fff, 0.1)
    tr
        border-right solid 1px alpha(#fff, 0.1)
    th
        background-color rgba(255, 255, 255, 0.1)
        border-bottom 2px solid rgba(255, 255, 255, 0.2)
        font-size 9pt
    td
        font-size: 9pt

    th.sortable
        cursor pointer
        user-select none
        position relative
        padding-right 20px

        &:hover
            background-color alpha(#fff, 0.2)

        &::after
            content ""
            position absolute
            left 10px
            top 50%
            transform translateY(-50%)
            border 4px solid transparent
            opacity 0.3

        &.sorted::after
            opacity 1

        &.asc::after
            border-bottom-color white
            margin-top -4px

        &.desc::after
            border-top-color white
            margin-top 4px

    th:nth-child(-n+4), td:nth-child(-n+4)
        text-align left
        &::after
            right 10px
            left auto

    tbody tr
        border-bottom 1px solid rgba(255, 255, 255, 0.1)

    tbody tr:nth-child(2n)
        background-color alpha(#fff, 0.05)

    tbody tr:hover
        background-color alpha(#fff, 0.2)

    tbody tr.warn
        background-color rgba(255, 100, 100, 0.2)
        opacity 0.7

    .positive
        color cd-up-green

    .negative
        color cd-down-red

    .absolute:before
        content: "("
        margin-right 2px
    .absolute:after
        content: ")"
        margin-left 2px

    .missing-factor 
        font-size 8pt
        // color #faba01
        color #caaa31
        font-weight: normal
    .missing-factor:before
        content: " x"

