// eventtradedetails styles
#eventtradedetails
    width 100%

#tradedetails-header-row
    display: flex
    justify-content: flex-end
    align-items: center
    gap 20px

#tradedetails-event-label
    font-weight: normal

#close-details-button
    height 30px
    width 30px
    margin-left: auto
    border-radius 10px
    svg
        color cd-dark-blue
        height inherit
        width inherit

#close-details-button.click-button::after
    background-color #000

#tradedetails-content-row
    margin-top 20px
    display flex
    gap 5px

#tradedetails-main-block
    position relative
    background-color cd-dark-blue
    // background-color #999
    width 100%
    box-sizing: border-box
    // padding 15px
    height 565px
    // color white
    border-radius: 3px

#tradedetails-side-block
    position relative
    background-color cd-dark-blue
    width 30%
    box-sizing: border-box
    padding 15px
    height 565px
    border-radius: 3px
    color #fff
    text-align: left

    // h2
    //     display flex
    //     justify-content: space-between
    //     margin-bottom 20px
    //     font-size 12pt
    h3
        font-size 9pt
        margin-bottom 3px
        color #ccc
    
    #tradedetails-chart-container
        width 100%
        height 100px
        position relative

    #tradedetails-direction
        font-weight: bold
        text-align: right
        margin-bottom 8px

    #tradedetails-direction.long
        color cd-up-green
    #tradedetails-direction.short
        color cd-down-red

    #tradedetails-range-selection
        display flex
        gap 5px
        .label
            margin-right 5px

    #tradedetails-entry-idx
    #tradedetails-exit-idx
    #tradedetails-next-date
    #tradedetails-next-entry
    #tradedetails-next-exit
        display flex
        align-items: center
        justify-content: space-between
        .click-button
            height 23px
            width 23px
        .click-button:hover
            background-color alpha(#fff, 0.2)
        .date
            padding 3px
            min-width 25px
        .value
            display flex
            justify-content: space-between
            align-items: center

    #tradedetails-win-rate
        margin-top 15px
        .label
            text-align: center

        #tradedetails-winning-rate
            display flex
            justify-content: center
            // justify-content: space-between
            align-items: center
            gap 30px
            margin 10px

        #tradedetails-win-rate-number
            font-size 11pt
            font-weight bold
            
        #tradedetails-win-rate-pie
            height 38px
            width 38px
            svg
                --color-profit: cd-up-green
                --color-loss: cd-down-red
                height inherit
                width inherit
                overflow: visible

    #tradedetails-summary-grid
        margin-top 15px
        display grid
        grid-template-columns: auto auto
        gap 8px            
        h3 
            text-align: center

    .value
        font-size: 11pt
        font-weight: bold
        text-align: center

    .missing-factor 
        font-size 9pt
        // color #faba01
        color #caaa31
        font-weight: normal

    .missing-factor:before
        content: " x"






