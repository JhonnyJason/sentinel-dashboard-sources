#forexscreener-result-hint
    display none
    margin auto
    color #fff

    p.error
        color cd-down-red
        background-color rgba(255, 100, 100, 0.15)
        border-left 3px solid cd-down-red
        padding 20px
        border-radius 3px

#forexscreener-result-preloader
    display none
    width 50px
    margin auto
    .preloader
        width 50px
        height 50px
        color #fff
