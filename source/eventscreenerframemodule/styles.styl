// eventscreenerframe styles
@import 'visibility.styl'

#eventscreenerframe
    padding 25px
    h2
        font-weight: bold
    input[type="checkbox"]
        accent-color: cd-dark-blue
    input[type="checkbox"]:focus
        box-shadow: 0 0 2px #666
        overflow: visible

#filter-head-row
#filter-content-row
#filter-properties-row
    display flex
    justify-content: space-between
    align-items: center

#filter-head-row
    margin-bottom 20px
    .click-button
        pointer-events none
        opacity 0.3
        filter: grayscale(100%)
        color white
        background-color cd-dark-blue
        border-radius: 5px
        border solid 2px
        box-shadow: 0 0 5px #000


    #filter-symbol-choice-head 
    #filter-event-choice-head
        display flex
        justify-content: space-between
        align-items: center
        padding 0 20px
        box-sizing: border-box
        // width 180px
        width 50%

    #choose-all-symbols-button
    #add-event-button
        display flex
        align-items: center
        line-height 25px
        padding 5px 12px
        svg
            width 25px
            height 25px
            margin-right 8px

    #symbol-select-eventscreener
        position relative

        .preloader
            z-index 5
            display none
            width 25px
            height 25px
            position absolute
            top 50%
            right 10px
            transform: translateY(-50%)
            color #888


#filter-content-row
    align-items: flex-start
    gap 4px
    padding 4px
    border-radius: 3px
    // background-color cd-dark-blue
    background-color #eee

#eventchoice
#filtersymbolchoice
    width 50%
    height 320px
    overflow-y auto

.edit-group
    display flex
    cursor pointer
    border-bottom solid 1px alpha(cd-dark-blue, 0.3) 
    // border: solid 1px alpha(cd-dark-blue, 0.3)
    // border-radius: 2px
    padding 2px 0
    // padding 2px 5px
    
    margin-left 3px
    input[type="text"]
        max-width 32px

    input
        border none
        padding 0
        font-size: 11pt
        text-align: right
        background-color: transparent

    input:focus
        padding 0

    svg
        height 15px
        width 15px

#event-choice-table
    width 100%
    min-height 100%
    background-color #fff
    font-size 11pt

    thead
        position sticky
        top 0
        background-color #fff
        outline: 2px solid #ddd
        line-height: 25px
        label
            display block
            white-space nowrap
        input[type="checkbox"]
            position: relative
            top 25px
    input[type="date"]
    input[type="date"]:focus
        padding 2px 5px
        background-color transparent
        border solid 1px alpha(cd-dark-blue, 0.3)
        outline: none
        border-radius: 2px
        width fit-content
    th
        padding 10px 20px

    
    tr.inactive
        filter grayscale(100%)
        opacity: 0.3
        pointer-events: none

    tr.separator
        height 30px
    tr:nth-child(2n)
        background-color alpha(#666, 0.05)
    td
        padding 10px 20px
        box-sizing: border-box

    .edit-group
        justify-content: flex-end
        gap 3px


#symbol-choice-list
    width 100%
    min-height 100%
    background-color #fff
    font-size 11pt
    .row
        display flex
        justify-content: space-between
        align-items: center
        padding 8px 20px
        height 40px
        box-sizing: border-box
        
    .row:nth-child(2n+1)
        background-color alpha(#666, 0.05)

    .label
        font-size: 14pt
        font-weight: bold

    .delete
        color cd-danger-red
        width 23px
        height 23px                



#filter-properties-row
    margin-top 20px
    padding 0 24px
    font-size 11pt
    justify-content: flex-start
    align-items: flex-start
    gap 50px

.filter-element
    display flex
    padding 3px 0
    opacity: 0.5
    .prop-title
        margin-right auto
    input.prop-value
        width 32px
        border none
        margin-left 5px    
        padding 0
        font-size: 11pt
        text-align: right

    input:focus
        padding 0
    .prop-unit
        margin 0 3px

.filter-element.active
    opacity: 1.0

.filter-element.for-short
    display none
.filter-element.for-long
    display none

#filter-properties-row.long-only
    .filter-element.for-long
        display flex

#filter-properties-row.short-only
    .filter-element.for-short
        display flex

#eventscreener-result-row
    width 100%
    min-height 20px
    padding 40px 20px
    box-sizing: border-box
    background-color cd-dark-blue
    border-radius: 3px
    margin-top 36px
    font-size 11pt

#eventscreener-result
    display: none
    width 100%
    table-layout: fixed
    box-sizing: border-box
    font-size 9pt
    color #fff
    border-collapse collapse

    th, td
        padding 8px 20px
        overflow hidden
        text-overflow: ellipsis

    td, tr
        border-left solid 1px alpha(#fff, 0.1)
    tr
        border-right solid 1px alpha(#fff, 0.1)
    th
        background-color rgba(255, 255, 255, 0.1)
        border-bottom 2px solid rgba(255, 255, 255, 0.2)
        text-align left

    th.sortable
        cursor pointer
        user-select none
        position relative
        padding-right 20px
        box-sizing: border-box

        &:hover
            background-color alpha(#fff, 0.2)

        &::after
            content ""
            position absolute
            right 7px
            top 50%
            transform translateY(-50%)
            border 4px solid transparent
            opacity 0.3

        &.sorted::after
            opacity 1

        &.asc::after
            border-bottom-color #fff
            margin-top -4px

        &.desc::after
            border-top-color #fff
            margin-top 4px

    tbody tr
        border-bottom 1px solid rgba(255, 255, 255, 0.1)

    tbody tr:nth-child(2n)
        background-color alpha(#fff, 0.05)

    tbody tr:hover
        background-color alpha(#fff, 0.2)

    tbody tr.warn
        background-color rgba(255, 100, 100, 0.2)
        opacity 0.7

    span.symbol
        font-weight: bold

    span.long
        font-weight: bold
        color cd-up-green

    span.short
        font-weight: bold
        color cd-down-red

    span.winrate:after
    span.profit:after
    span.up:after
    span.down:after
        content "%"
        margin-left 2px

    span.profit
    span.up
        color cd-up-green

    span.profit:before
    span.up:before
        content "+"
        margin-right 2px

    span.down
        color cd-down-red



        
#eventscreener-result-hint
    display none
    margin auto
    color #fff
    
#eventscreener-result-preloader
    display none
    width 50px
    margin auto
    .preloader
        width 50px
        height 50px
        color #fff
