// seasonalityframe styles
@import "uplot-chart.styl"
@import "chart-components.styl"

#cursor-indicator
    position absolute
    top 10px
    left 10px
    background-color #fff
    border-radius 2px
    display: none // should turn to flex in visibility.styl
    align-items: center
    padding 5px 10px 5px 3px
    gap 3px
    svg
        position relative
        width 20px
        height 20px

#reset-time-axis-button
    position absolute
    bottom 10px
    right 10px
    display none
    color white
    height 30px
    width 30px
    // transition transform 0.2s ease-out
    svg
        height inherit
        width inherit

#reset-time-axis-button:hover
    animation nudge-right 0.4s ease-in-out

@keyframes nudge-right
    0%
        transform translateX(3px)
    50%
        transform translateX(-2px)
    100%
        transform translateX(0)


#seasonality-chart
    position absolute
    top 0
    left 0
    height 100%
    width 100%
    overflow: visible
    opacity: 0
    pointer-events: none
    z-index -1