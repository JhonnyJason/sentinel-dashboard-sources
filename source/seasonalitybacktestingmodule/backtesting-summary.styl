#backtesting-summary-tab
    // position relative
    display none
    color #fff
    overflow: visible
    text-align: left
    padding 20px

    h2
        display flex
        justify-content: space-between
        margin-bottom 20px
        font-size 12pt
    h3 
        font-size 9pt
        margin-bottom 3px
        color #ccc

    #trade-details
        .value
            display flex
            justify-content: space-between
            align-items: center
            margin-bottom 12px

    #backtesting-entry
    #backtesting-exit
        display flex
        align-items: center
        .click-button
            height 23px
            width 23px
        .click-button:hover
            background-color alpha(#fff, 0.2)
        .date   
            padding 3px 7px


    #backtesting-summary-grid
        margin-top 15px
        display grid
        grid-template-columns: auto auto
        gap 10px            
        h3 
            text-align: center

    .value
        font-size: 11pt
        font-weight: bold
        margin 0 10px
        text-align: center
    

    #backtesting-connector
        background-color cd-dark-blue
        width 100%
        height 30px
        position absolute
        bottom -25px
        left 0

    #backtesting-direction
        font-weight: bold

    #backtesting-direction.long
        color cd-up-green

    #backtesting-direction.short
        color cd-down-red

    #backtesting-winning-rate
        display flex
        justify-content: center
        // justify-content: space-between
        align-items: center
        gap 30px
        margin 10px

    #win-rate-number
        font-size 13pt
        font-weight bold
        
    #win-rate-pie
        height 45px
        width 45px
        svg
            --color-profit: cd-up-green
            --color-loss: cd-down-red
            height inherit
            width inherit